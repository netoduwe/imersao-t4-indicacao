---
interface Props {
    sales: number;
}

const { sales } = Astro.props;

const tiers = [
    { threshold: 3, label: '3 Vendas', reward: 'Bônus', icon: '🎁' },
    { threshold: 10, label: '10 Vendas', reward: 'VIP', icon: '💎' },
    { threshold: 25, label: '25 Vendas', reward: 'Backstage', icon: '👑' },
];

const maxThreshold = tiers[tiers.length - 1].threshold;
const progressPercentage = Math.min((sales / maxThreshold) * 100, 100);
---

<div class="space-y-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div>
            <h2 class="text-3xl font-bold text-sage-800 tracking-tight leading-tight">Seu Progresso</h2>
            <p class="text-sage-500 text-sm">Indique e desbloqueie prêmios exclusivos.</p>
        </div>
        <div class="bg-sage-600 px-8 py-4 rounded-3xl text-white text-center shadow-xl shadow-sage-200 min-w-[160px]">
            <span class="block text-[10px] uppercase font-bold tracking-widest opacity-80 mb-1">Total de Vendas</span>
            <span class="text-4xl font-bold leading-none">{sales}</span>
        </div>
    </div>

    <div class="card-premium pt-20 pb-12 px-10 relative overflow-visible bg-white">
        <!-- Linha de Base -->
        <div class="h-2 bg-sage-50 rounded-full w-full relative">
            <!-- Barra de Progresso Real -->
            <div 
                class="h-full bg-sage-500 rounded-full absolute top-0 left-0 transition-all duration-1000 shadow-sm" 
                style={`width: ${progressPercentage}%`}
            >
                <div class="absolute right-0 -top-1.5 w-5 h-5 bg-white border-4 border-sage-500 rounded-full shadow-md z-10"></div>
            </div>

            <!-- Pontos dos Tiers -->
            <div class="absolute inset-0 w-full h-full">
                {tiers.map((tier) => {
                    const isUnlocked = sales >= tier.threshold;
                    const position = (tier.threshold / maxThreshold) * 100;
                    return (
                        <div class="absolute top-1/2 -translate-y-1/2" style={`left: ${position}%`}>
                            <!-- Marcador na linha -->
                            <div class={`w-2 h-2 rounded-full transition-colors duration-500 ${isUnlocked ? 'bg-sage-500' : 'bg-sage-200'}`}></div>
                            
                            <!-- Card flutuante (Ícone + Texto) -->
                            <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center group">
                                <div class={`w-12 h-12 rounded-2xl flex items-center justify-center text-xl transition-all duration-500 shadow-sm mb-2 ${isUnlocked ? 'bg-sage-500 text-white scale-110 shadow-lg' : 'bg-white border border-sage-100 text-sage-200'}`}>
                                    {tier.icon}
                                </div>
                            </div>

                            <!-- Labels inferiores -->
                            <div class="absolute top-6 left-1/2 -translate-x-1/2 text-center min-w-[100px]">
                                <span class={`block font-bold text-[10px] uppercase tracking-wider mb-0.5 ${isUnlocked ? 'text-sage-800' : 'text-sage-300'}`}>
                                    {tier.label}
                                </span>
                                <span class={`block text-[9px] font-medium leading-none ${isUnlocked ? 'text-sage-500' : 'text-sage-200'}`}>
                                    {tier.reward}
                                </span>
                            </div>
                        </div>
                    );
                })}
            </div>
        </div>
    </div>
</div>
